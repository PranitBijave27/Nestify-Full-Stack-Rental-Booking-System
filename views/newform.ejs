<%- layout("layouts/boilerplate") %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
      
      <div class="card shadow-sm border-0 rounded-4 p-4 p-lg-5">
        <h2 class="fw-bold text-dark mb-1">Create a <span class="text-rose">New Nest</span></h2>
        <p class="text-muted mb-4">Fill in the details to list your property.</p>

        <form action="/listing" method="post" class="needs-validation" novalidate enctype="multipart/form-data">

          <div class="mb-3">
            <label class="form-label fw-semibold">Title</label>
            <input type="text" class="form-control" name="title" 
                   placeholder="e.g. Cozy Beachside Villa" required>
            <div class="invalid-feedback">Please provide a catchy title for your property.</div>
          </div>

          <div class="mb-3">
            <label class="form-label fw-semibold">Description</label>
            <textarea class="form-control" name="description" rows="3" 
                      placeholder="Tell guests what makes your place special..." required></textarea>
            <div class="invalid-feedback">A brief description helps guests choose your nest.</div>
          </div>

          <div class="mb-3">
            <label class="form-label fw-semibold">Upload Image</label>
            <input type="file" class="form-control" name="image" required>
            <div class="invalid-feedback">Please select a high-quality photo.</div>
          </div>

          <div class="row">
            <div class="col-md-6 mb-3">
              <label class="form-label fw-semibold">Price (₹)</label>
              <input type="number" class="form-control" name="price" min="1" 
                     placeholder="e.g. 1200" required>
              <div class="invalid-feedback">Price must be at least 1.</div>
            </div>

              <div class="mb-4">
            <label class="form-label fw-semibold">Location</label>
            <input type="text" class="form-control" name="location" 
                   placeholder="e.g. Goa, Maharashtra" required>
            <div class="invalid-feedback">Tell us exactly where this nest is located.</div>
          </div>

            <div class="col-md-5 mb-3">
              <label class="form-label fw-semibold">Country</label>
              <input type="text" class="form-control" name="country" 
                     placeholder="India" required>
              <div class="invalid-feedback">Please enter the country name.</div>
            </div>
          </div>

          <button class="btn btn-rose w-100 border-0 py-2 shadow-sm" this.innerText='Submitting...'">
            <i class="fa-solid fa-cloud-arrow-up me-2"></i>Publish Listing
          </button>

          <div class="text-center mt-3">
            <a href="/listing" class="text-muted small text-decoration-none">Cancel and go back</a>
          </div>

        </form>
      </div>

    </div>
  </div>
</div>
