<%- layout("/layouts/boilerplate") %>
<div class="filters-wrapper">
  <div class="container">
    <div class="filters-bar">
      <a href="/listing?category=beach" class="filter-item">
        <i class="fa-solid fa-water"></i>
        <span>Beach</span>
      </a>
      <a href="/listing?category=mountain" class="filter-item">
        <i class="fa-solid fa-mountain"></i>
        <span>Mountain</span>
      </a>
      <a href="/listing?category=cabin" class="filter-item">
        <i class="fa-solid fa-house"></i>
        <span>Cabins</span>
      </a>
      <a href="/listing?category=city" class="filter-item">
        <i class="fa-solid fa-city"></i>
        <span>City</span>
      </a>
      <a href="/listing?category=lake" class="filter-item">
        <i class="fa-solid fa-water-ladder"></i>
        <span>Lakes</span>
      </a>
      <a href="/listing?category=luxury" class="filter-item">
        <i class="fa-solid fa-gem"></i>
        <span>Luxury</span>
      </a>
      <a href="/listing?category=camping" class="filter-item">
        <i class="fa-solid fa-campground"></i>
        <span>Camping</span>
      </a>
      <a href="/listing?category=farm" class="filter-item">
        <i class="fa-solid fa-tractor"></i>
        <span>Farm</span>
      </a>
      <a href="/listing?category=snow" class="filter-item">
        <i class="fa-regular fa-snowflake"></i>
        <span>Snowy</span>
      </a>
      <a href="/listing?category=castle" class="filter-item">
        <i class="fa-brands fa-fort-awesome"></i>
        <span>Castle</span>
      </a>
    </div>
  </div>
</div>
<div class="container mt-4 mb-5">
  <h2 class="mb-4 fw-bold">Explore <span class="text-rose">Destinations</span></h2>

  <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    <% if(allListings.length>0) {%>
    <% allListings.forEach(function(listing) { %>
      <% let optimizedUrl = listing.image.url.replace("/upload", "/upload/w_400,c_fill,q_auto,f_auto");%>
      <div class="col">
        <div class="listing-card h-100"> <a href="/listing/<%= listing._id %>" class="text-decoration-none">
            <div class="position-relative overflow-hidden rounded-top-4">
              <img src="<%= optimizedUrl %>" class="card-img-top" alt="<%= listing.title %>" loading="lazy">
              <div class="card-img-overlay d-flex justify-content-end align-items-start">
                <i class="fa-regular fa-heart fs-4 text-white"></i>
              </div>
            </div>
          </a>
          <div class="card-body px-1">
            <a href="/listing/<%= listing._id %>" class="text-decoration-none text-dark">
              <div class="d-flex justify-content-between align-items-center mb-1">
                <h5 class="card-title mb-0 text-truncate fw-bold"><%= listing.title %></h5>
                <span class="price-tag">₹<%= listing.price.toLocaleString("en-IN") %> <small class="text-muted fw-normal">/ night</small></span>
              </div>
              <p class="card-text text-muted small mb-3">
                <i class="fa-solid fa-location-dot me-1 text-rose"></i> <%= listing.location %>, <%= listing.country %>
              </p>
            </a>
          </div>

        </div>
      </div>
    <% }); %>
  </div>
  <% } else{%>
    <div class="col-12 mt-5 mb-5" style="width: 100%;">
        <div class="d-flex flex-column align-items-center justify-content-center text-center mx-auto" style="min-height: 40vh;">
            <i class="fa-solid fa-magnifying-glass-location fa-4x mb-4 text-muted" style="opacity: 0.5;"></i>
            <h2 class="fw-bold">No Nests Found</h2>
            <p class="text-muted">We couldn't find anything matching "<strong><%= search %></strong>".<br>Try checking your spelling or searching for a broader location.</p>
            <a href="/listing" class="btn btn-dark mt-3 px-5 rounded-pill shadow-sm">Explore All</a>
        </div>
    </div>
    <% } %>
</div>